{
	admin :2019
	http_port 8080
}

localhost:8443, 127.0.0.1:8443, 127.0.0.1.nip.io:8443 {
	tls internal
	root * /home/vboxuser/dash-content

	# Reverse proxy: API requests → Python network throttling server
	handle /api/* {
		reverse_proxy http://127.0.0.1:8888
	}

	# Static file server for everything else
	handle {
		file_server
	}

	log {
		output file logs/access.log
		format json {
			time_format wall
		}
	}
	header {
		Access-Control-Allow-Origin *
		Cache-Control "public, max-age=3600"
		Alt-Svc "h3=\":8443\"; ma=2592000, h3-29=\":8443\"; ma=2592000, h3-32=\":8443\"; ma=2592000"
	}
}
